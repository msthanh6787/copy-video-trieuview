{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and credit balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "credits": { "type": "number", "description": "Remaining credits for analysis" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "registrationIp": { "type": "string", "description": "Status of IP verification" }
      },
      "required": ["uid", "email", "credits"]
    },
    "IPRegistration": {
      "title": "IPRegistration",
      "description": "Tracking IP addresses for rate limiting",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "uid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["ip", "uid", "timestamp"]
    },
    "Order": {
      "title": "Order",
      "description": "Credit purchase orders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "credits": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "credits", "status"]
    },
    "AnalysisHistory": {
      "title": "AnalysisHistory",
      "description": "History of video analyses",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "scenes": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fileName", "scenes"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Credit purchase records"
    },
    "/history/{historyId}": {
      "schema": "AnalysisHistory",
      "description": "User analysis history"
    },
    "/ip_registrations/{regId}": {
      "schema": "IPRegistration",
      "description": "IP address registration tracking"
    }
  }
}
